# PostgreSQL database (Neon)
DATABASE_URL=<PUT_YOUR_DATABASE_URL_HERE>
# LLM — Ollama (local, no API key needed)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_CHOICE=<CHOOSE_YOUR_MODEL>
INGESTION_LLM_CHOICE=llama3.2

# Embeddings — Ollama nomic-embed-text (768 dimensions, local)
# Run: ollama pull nomic-embed-text
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
VECTOR_DIMENSION=768

# Neo4j knowledge graph
# password is what you set in Neo4j Desktop
NEO4J_URI=<ADD_URI://127.0.0.1:XXXX>
NEO4J_USER=<neo4j>
NEO4J_PASSWORD=<PUT_YOUR_PASSWORD_HERE>

# Application
APP_ENV=development
LOG_LEVEL=INFO
APP_PORT=8058
